# Copy to .env — docker compose picks it up automatically.
# Cloud LLM providers become selectable in the app's Settings once their key is set;
# without keys everything runs on local Ollama.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides (defaults shown)
#CLAUDE_MODEL=claude-sonnet-5
#GEMINI_MODEL=gemini-2.5-flash

# Ollama — override the URL to point at a remote/different host, or the model names
# to use a different pulled model (defaults shown; the model must be pulled first:
# `docker exec idea-scraper-ollama-1 ollama pull <model>`).
#LLM_BASE_URL=http://ollama:11434/v1
#SUMMARY_MODEL=qwen3:8b
#REASONING_MODEL=qwen3:8b

# Embeddings always stay on local Ollama (bge-large, 1024-dim) — switching them would
# invalidate the existing Qdrant collection.
