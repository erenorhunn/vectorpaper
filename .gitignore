# Generated on 2026-07-08
# Includes: docker, python, flutter

### Universal ###
# Common files that should be ignored in all projects

# Logs
*.log
# Temporary files
*.tmp
*~

*.bak
# Environment files (containing secrets, API keys, credentials)
.env
*.env
.env.*

# Local configuration that shouldn't be shared
*.local

### Docker ###
# Docker environment specific files and directories

# Common directories to exclude
node_modules/
bower_components/
target/
dist/

build/
.cache/
